# =========================================================
# Root .gitignore
# Project: Next.js frontend + NestJS backend + Prisma + Docker
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
**/node_modules/

# Package manager caches
.npm/
**/.npm/
.pnpm-store/
**/.pnpm-store/
.yarn/
**/.yarn/
.yarn-cache/
**/.yarn-cache/

# ---------------------------------------------------------
# Environment variables and secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template

**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template

# Local secret/config files
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
secrets/
**/secrets/

# ---------------------------------------------------------
# Build outputs
# ---------------------------------------------------------

# Next.js
.next/
**/.next/
out/
**/out/

# NestJS / TypeScript / Node
dist/
**/dist/
build/
**/build/
# lib/
# **/lib/

# TypeScript incremental build info
*.tsbuildinfo

# Turbo / monorepo caches
.turbo/
**/.turbo/

# Generic caches
.cache/
**/.cache/
.parcel-cache/
**/.parcel-cache/
.eslintcache
**/.eslintcache
.stylelintcache
**/.stylelintcache

# ---------------------------------------------------------
# Testing and coverage
# ---------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
test-results/
**/test-results/
playwright-report/
**/playwright-report/
blob-report/
**/blob-report/

# Jest/Vitest caches
.jest-cache/
**/.jest-cache/
.vitest/
**/.vitest/

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
**/logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
debug.log*

# Process/runtime files
*.pid
*.pid.lock
*.seed
*.retry
pids/
**/pids/

# ---------------------------------------------------------
# Prisma / Database
# ---------------------------------------------------------

# Local SQLite databases
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal

# Database dumps and backups
*.sql
*.dump
*.backup
*.bak

# Keep Prisma schema and migrations tracked
!**/prisma/schema.prisma
!**/prisma/migrations/
!**/prisma/migrations/**

# Prisma generated temporary artifacts
**/prisma/.cache/
**/.prisma/

# ---------------------------------------------------------
# Uploaded and generated user files
# ---------------------------------------------------------
uploads/
**/uploads/
public/uploads/
**/public/uploads/

# Keep empty upload directories when a .gitkeep exists
!uploads/.gitkeep
!**/uploads/.gitkeep
!public/uploads/.gitkeep
!**/public/uploads/.gitkeep

# Temporary file processing directories
tmp/
**/tmp/
temp/
**/temp/

# Generated exports/reports
exports/
**/exports/
reports/generated/
**/reports/generated/

# Spreadsheet/import temporary files
*.xlsx~
~$*.xlsx
~$*.xls
*.csv.tmp

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------

# Local Docker override files
docker-compose.override.yml
docker-compose.override.yaml
compose.override.yml
compose.override.yaml

# Docker runtime data
docker-data/
**/docker-data/
postgres-data/
**/postgres-data/
redis-data/
**/redis-data/

# Local volumes/backups
volumes/
**/volumes/

# ---------------------------------------------------------
# IDEs and editors
# ---------------------------------------------------------

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
!.vscode/launch.example.json
!.vscode/tasks.example.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Visual Studio
.vs/

# Vim
*.swp
*.swo
*.swn
*~

# ---------------------------------------------------------
# Operating system files
# ---------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ---------------------------------------------------------
# Next.js / deployment platforms
# ---------------------------------------------------------
.vercel/
**/.vercel/
.netlify/
**/.netlify/

# Next.js generated files
next-env.d.ts

# Optional: comment the previous line if you prefer tracking next-env.d.ts

# ---------------------------------------------------------
# NestJS / Node runtime
# ---------------------------------------------------------
.nest/
**/.nest/

# REPL/history
.node_repl_history

# ---------------------------------------------------------
# Linting / formatting temporary files
# ---------------------------------------------------------
.prettiercache
**/.prettiercache

# ---------------------------------------------------------
# Archives and large generated bundles
# ---------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ---------------------------------------------------------
# Local notes and scratch files
# ---------------------------------------------------------
scratch/
**/scratch/
.todo
TODO.local.md
notes.local.md

# ---------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------
*.local
*.tmp
*.temp
*.orig
*.rej
*.zip
# Do not ignore source maps by default.
# Uncomment if you do not want source maps committed:
# *.map
